# 复制为 .env.local 做本地调试；Cloudflare Pages 控制台配置同名「环境变量」
# 勿把真实密钥提交到 git

NEXT_PUBLIC_ENABLE_QUIZ_ANALYTICS=1
NEXT_PUBLIC_QUIZ_ANALYTICS_INGEST_URL=worker的地址

# 若 Worker 设置了 INGEST_SECRET（wrangler secret），这里填相同字符串：
# NEXT_PUBLIC_QUIZ_ANALYTICS_TOKEN=

# 可选：Cloudflare Web Analytics
# NEXT_PUBLIC_CF_BEACON_TOKEN=
